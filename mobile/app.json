{
  "expo": {
    "name": "Penny",
    "slug": "penny",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "dev.codebyram.penny"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "penny",
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#FAF7F2",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#171310"
          }
        }
      ],
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "5e0cc1af-e214-4a5f-af6e-f8edce8d9479"
      }
    },
    "owner": "sriram52",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5e0cc1af-e214-4a5f-af6e-f8edce8d9479"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}

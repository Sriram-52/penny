# Copy to .env (gitignored). EXPO_PUBLIC_* values are inlined into the JS
# bundle at build time — never put real secrets you care about here.

# Where the app sends notes for parsing. Leave unset to use the built-in
# offline stub parser (regex-based, everything comes back low-confidence).
# Dev: your Mac's LAN IP + the dev server port.
#   EXPO_PUBLIC_PARSE_URL=http://192.168.1.20:8787/parse
# Prod: the Lambda Function URL.
#   EXPO_PUBLIC_PARSE_URL=https://xxxx.lambda-url.us-east-1.on.aws/
EXPO_PUBLIC_PARSE_URL=

# Sent as x-app-secret; must match the Lambda's APP_SECRET env var.
# The dev server ignores it.
EXPO_PUBLIC_APP_SECRET=

# Currency used by the offline stub parser (the AI parser gets this from the
# server's DEFAULT_CURRENCY instead).
EXPO_PUBLIC_CURRENCY=USD
